GITHUB_TOKEN=
LLM_API_KEY=

# Optional runtime settings
RS_GITHUB_REPO=thinson/RS-PaperClaw
GITHUB_TIMEOUT=15
GITHUB_RETRY=2
LLM_MODEL=deepseek-v4-flash
LLM_API_URL=https://api.deepseek.com/chat/completions
