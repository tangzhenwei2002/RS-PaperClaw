ARXIV_USER_AGENT=RS-PaperClaw/1.0 (+https://github.com/thinson/RS-PaperClaw)
RS_TEMP_DIR=/tmp
RS_FILTER_KEYWORDS_FILE=scripts/config/filter_keywords.json
RS_FILTER_PROMPT_FILE=scripts/prompts/filter_cross_prompt.md

# Optional network / integration settings
RS_PROXY_URL=
